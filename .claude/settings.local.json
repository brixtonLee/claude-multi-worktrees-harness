      "Bash(git push --force-with-lease * master)",
      "Bash(git push --force-with-lease * develop)",
      "Bash(git push -f * main)",
      "Bash(git push -f * master)",
      "Bash(git push -f * develop)",
      "Bash(git push --delete * main)",
      "Bash(git push --delete * master)",
      "Bash(git push --delete * develop)",
      "Bash(git push origin :main)",
      "Bash(git push origin :master)",
      "Bash(git push origin :develop)",
      "Bash(git push * main)",
      "Bash(git push * master)",
      "Bash(git push --mirror *)",
      "Bash(git reset --hard origin/main)",
      "Bash(git reset --hard origin/master)",
      "Bash(git reset --hard origin/develop)"
