      "Bash(git branch -D feature*)",
      "Bash(git branch -D bugfix*)",
      "Bash(git branch -D hotfix*)",
      "Bash(git branch -D integration*)",
      "Bash(git branch -d sprint*)",
      "Bash(git branch -d feature*)",
      "Bash(git branch -d bugfix*)",
      "Bash(git branch -d hotfix*)",
      "Bash(git branch -d integration*)",

      "Bash(git clean -fd)",
      "Bash(git clean -f)",
      "Bash(git reset --hard HEAD)",
      "Bash(git reset --hard HEAD~*)",
      "Bash(git reset --hard origin/*)",

      "Bash(dotnet build:*)",
      "Bash(dotnet build *)",
      "Bash(dotnet build)",
      "Bash(dotnet test:*)",
      "Bash(dotnet test *)",
      "Bash(dotnet test)",
      "Bash(dotnet format:*)",
      "Bash(dotnet format *)",
      "Bash(dotnet format)",
      "Bash(dotnet restore *)",
      "Bash(dotnet restore)",
      "Bash(dotnet run *)",
      "Bash(dotnet run)",

      "Bash(git merge integration*)",
      "Bash(git merge sprint/*)",
      "Bash(git rebase integration*)",
      "Bash(git rebase sprint/*)",
      "Bash(git push * integration*)",
